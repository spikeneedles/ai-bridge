BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8765
DB_PATH=bridge.db

# ── Agent Runners ──────────────────────────────────────────────
# Copilot API runner (uses your existing GitHub token)
GITHUB_TOKEN=your_github_pat_here

# Gemini API runner
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Runner mode: "api" (direct API calls) or "cli" (subprocess)
RUNNER_MODE=api

# Daemon poll interval in seconds
DAEMON_POLL_INTERVAL=5

# ── Orchestrator LLM ───────────────────────────────────────────
# Which LLM to use for goal decomposition and step refinement
# Options: openai | gemini | ollama | copilot
ORCHESTRATOR_LLM=copilot

# If using openai:
# ORCHESTRATOR_API_KEY=sk-...
# ORCHESTRATOR_MODEL=gpt-4o-mini

# If using ollama (free, local):
# ORCHESTRATOR_LLM=ollama
# ORCHESTRATOR_BASE_URL=http://localhost:11434/v1
# ORCHESTRATOR_MODEL=llama3

